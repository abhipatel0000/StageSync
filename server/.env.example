# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database Configuration
# Set DB_DIALECT to 'sqlite' for local development or 'mysql' for production
DB_DIALECT=mysql
DB_STORAGE=./database.sqlite

# MySQL Configuration (Only required if DB_DIALECT=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=stagesync

# JWT Secrets (Use strong random keys in production; must be set in env in production)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# File Storage Configuration
# Set STORAGE_PROVIDER to 'local' for local disk uploads or 's3' for Cloudflare R2 / AWS S3
STORAGE_PROVIDER=s3
LOCAL_STORAGE_DIR=./uploads

# S3 / Cloudflare R2 Settings (Only required if STORAGE_PROVIDER=s3)
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your_r2_access_key_id
S3_SECRET_ACCESS_KEY=your_r2_secret_access_key
S3_BUCKET_NAME=stagesync-event-files
S3_REGION=auto

# Security & Rate Limiting
PIN_RATE_LIMIT_WINDOW_MS=900000
PIN_RATE_LIMIT_MAX=5
MAX_FILE_SIZE=104857600
